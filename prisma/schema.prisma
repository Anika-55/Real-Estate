generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  AGENT
}

enum PropertyType {
  RENT
  SALE
}

enum BookingStatus {
  PENDING
  CONFIRMED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  id          String     @id @default(uuid())
  name        String
  email       String     @unique
  password    String
  role        UserRole   @default(USER)
  phone       String?
  properties  Property[]
  bookings    Booking[]
  payments    Payment[]
  reviews     Review[]
  favorites   Favorite[]
  refreshTokens RefreshToken[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Property {
  id          String       @id @default(uuid())
  title       String
  description String
  price       Decimal      @db.Decimal(12, 2)
  type        PropertyType
  city        String
  country     String
  address     String
  images      String[]
  bedrooms    Int?
  bathrooms   Int?
  area        Int?
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  bookings    Booking[]
  reviews     Review[]
  favorites   Favorite[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([ownerId])
  @@index([city, country])
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  propertyId String
  date       DateTime
  status     BookingStatus @default(PENDING)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payment    Payment?
  createdAt  DateTime      @default(now())

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@index([date])
  @@unique([userId, propertyId, date])
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  bookingId       String        @unique
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  stripeSessionId String?       @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([status])
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  rating     Int
  comment    String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
